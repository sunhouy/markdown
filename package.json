{
  "name": "md",
  "version": "1.0.0",
  "description": "基于Vditor的移动端轻量化在线markdown编辑器，可进行多文件管理。支持可视化插入格式、公式、图表，上传文件和图片，降低学习和操作门槛；支持多端文件同步，历史版本，文件分享，日间、夜间模式切换，导入本地文件，导出文档，云打印功能",
  "main": "api/server.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "check-deploy": "node scripts/check-deploy.js",
    "start": "node api/server.js",
    "build:electron": "electron-builder -l"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunhouy/markdown.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sunhouy/markdown/issues"
  },
  "homepage": "https://github.com/sunhouy/markdown#readme",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jquery": "^3.7.1",
    "jspdf": "^4.2.0",
    "jstree": "^3.3.17",
    "markdown-it": "^14.1.1",
    "markdown-it-mathjax3": "^5.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "pdfjs-dist": "^4.4.168",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "vditor": "^3.11.2",
    "wkhtmltopdf": "^0.4.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.2.0"
  },
  "build": {
    "appId": "cn.yhsun.md",
    "productName": "MarkdownEditor",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
