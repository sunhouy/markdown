{
  "name": "md",
  "version": "1.0.0",
  "description": "基于Vditor的移动端轻量化在线markdown编辑器，可进行多文件管理。支持可视化插入格式、公式、图表，上传文件和图片，降低学习和操作门槛；支持多端文件同步，历史版本，文件分享，日间、夜间模式切换，导入本地文件，导出文档，云打印功能",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "node version.js && vite build",
    "preview": "vite preview",
    "test": "jest",
    "check-deploy": "node scripts/check-deploy.js",
    "start": "node api/server.js",
    "build:electron:win": "electron-builder -w --x64 --publish=never",
    "build:electron:linux": "electron-builder -l AppImage deb --x64 --publish=never",
    "bump-version": "node version.js",
    "cap:init": "cap init",
    "cap:add:android": "cap add android",
    "cap:sync": "npm run build && cap sync",
    "cap:open:android": "cap open android",
    "cap:build:android": "npm run cap:sync && cd android && ./gradlew assembleRelease"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunhouy/markdown.git"
  },
  "keywords": [],
  "author": {
    "name": "sunhouyun",
    "email": "no-reply@md.yhsun.cn"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sunhouy/markdown/issues"
  },
  "homepage": "https://github.com/sunhouy/markdown#readme",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jquery": "^3.7.1",
    "jspdf": "^4.2.1",
    "jstree": "^3.3.17",
    "markdown-it": "^14.1.1",
    "markdown-it-mathjax3": "^5.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "pdfjs-dist": "^4.4.168",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "vditor": "^3.11.2",
    "wkhtmltopdf": "^0.4.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.2.0"
  },
  "build": {
    "appId": "cn.yhsun.md",
    "productName": "MarkdownEditor",
    "directories": {
      "output": "dist-electron-new"
    },
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "electron-main.js",
      "preload.js",
      "icon.png",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
